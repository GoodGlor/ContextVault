# ContextVault environment configuration.
# Copy to `.env` and adjust for your local setup.

ENVIRONMENT=development

# Secret used for signing JWTs — MUST be overridden outside development.
# Use at least 32 bytes of randomness (e.g. `openssl rand -hex 32`).
SECRET_KEY=change-me-in-production

# JWT session lifetime, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Async SQLAlchemy connection string (matches docker-compose defaults).
DATABASE_URL=postgresql+asyncpg://contextvault:contextvault@localhost:5432/contextvault

# Optional defaults for `python -m contextvault.cli create-admin`.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=change-me
