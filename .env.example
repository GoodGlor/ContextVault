# ContextVault environment configuration.
# Copy to `.env` and adjust for your local setup.

ENVIRONMENT=development

# Secret used for signing JWTs — MUST be overridden outside development.
# Use at least 32 bytes of randomness (e.g. `openssl rand -hex 32`).
SECRET_KEY=change-me-in-production

# JWT session lifetime, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Async SQLAlchemy connection string (matches docker-compose defaults).
DATABASE_URL=postgresql+asyncpg://contextvault:contextvault@localhost:5432/contextvault

# Local embedding model (sentence-transformers) and its vector width. The two
# MUST agree with the pgvector column; changing them means re-embedding. bge-m3
# is multilingual (RU/UK/EN) and 1024-dim. Alternative: intfloat/multilingual-e5-large.
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIM=1024

# Generation — the Anthropic (Claude) LLM provider. The API key authenticates the
# SDK; the model is configurable (defaults to claude-opus-4-8). LLM_MAX_TOKENS
# caps the generated answer length.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
# LLM_MAX_TOKENS=2048

# Optional defaults for `python -m contextvault.cli create-admin`.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=change-me
